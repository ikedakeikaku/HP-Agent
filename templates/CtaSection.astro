---
interface Props {
  headline?: string;
  subtext?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

// ★ 生成時に業種に応じてデフォルト値を書き換える
// consulting: "まずはお気軽にご相談ください" / medical: "ご予約はこちら"
// restaurant: "ご予約・お問い合わせ" / it-service: "まずは資料をダウンロード"
const {
  headline = "{{CTA_HEADLINE}}",
  subtext = "{{CTA_SUBTEXT}}",
  primaryText = "{{CTA_PRIMARY_TEXT}}",
  primaryHref = "/contact/",
  secondaryText = "{{CTA_SECONDARY_TEXT}}",
  secondaryHref = "{{CTA_SECONDARY_HREF}}",
} = Astro.props;
---

<section class="bg-primary py-20 px-4">
  <div class="max-w-[1080px] mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
      {headline}
    </h2>
    <p class="text-gray-300 text-lg mb-10">
      {subtext}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={primaryHref}
        class="inline-block bg-accent text-white font-bold py-4 px-10 rounded-lg text-lg hover:bg-accent-hover transition-colors"
      >
        {primaryText}
      </a>
      {secondaryText && (
        <a
          href={secondaryHref}
          class="inline-block border-2 border-white/30 text-white font-bold py-4 px-10 rounded-lg text-lg hover:bg-white/10 transition-colors"
        >
          {secondaryText}
        </a>
      )}
    </div>
  </div>
</section>
