---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center mb-12">
  <p class="text-sm font-bold text-accent tracking-widest uppercase mb-2">{subtitle}</p>
  <h2 class="text-2xl md:text-3xl font-bold text-primary">{title}</h2>
</div>
